{
    "name": "jobio-frontend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "check:format": "prettier --write \"./!(node_modules|.next)/**/*.{ts,tsx,js,jsx}\"",
        "check:typescript": "tsc --noEmit -p .",
        "check:eslint": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
        "check": "npm run check:format && npm run check:typescript && npm run check:eslint",
        "prepare": "husky"
    },
    "dependencies": {
        "@emotion/cache": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/material": "^7.2.0",
        "@mui/material-nextjs": "^7.2.0",
        "@tanstack/react-query": "^5.81.5",
        "axios": "^1.10.0",
        "husky": "^9.1.7",
        "next": "15.2.0",
        "next-intl": "^4.3.4",
        "prettier": "^3.6.2",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "zustand": "^5.0.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.29.0",
        "@next/eslint-plugin-next": "^15.3.4",
        "@tanstack/eslint-plugin-query": "^5.81.2",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9.29.0",
        "eslint-config-next": "^15.3.4",
        "eslint-config-prettier": "^10.1.5",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-promise": "^7.2.1",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-unused-imports": "^4.1.4",
        "sass": "^1.89.2",
        "typescript": "^5",
        "typescript-eslint": "^8.34.1"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "npm run check"
        ],
        "*.{json,css,md}": [
            "prettier --write"
        ]
    }
}
